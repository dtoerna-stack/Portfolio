  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "25.9.1",
    "svelte-check": "4.4.8",
    "tailwindcss": "^4.1.17",
    "typescript": "6.0.3"
  }
